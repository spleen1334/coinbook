{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "read": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "todowrite": "allow",
    "question": "allow",
    "skill": "allow",
    "task": "allow",
    "edit": "allow",
    "write": "allow",
    "bash": {
      "*": "ask",
      "git status": "allow",
      "git status *": "allow",
      "git diff": "allow",
      "git diff *": "allow",
      "git log *": "allow",
      "git show *": "allow",
      "git add *": "allow",
      "git commit *": "allow",
      "npm run check": "allow",
      "npm run build": "allow",
      "npm run build:pages": "allow",
      "npm run deploy": "allow",
      "npx prettier --write *": "allow",
      "rm *": "deny",
      "sudo *": "deny",
      "git clean *": "deny",
      "git reset --hard *": "deny",
      "git push *": "ask"
    },
    "external_directory": {
      "*": "deny"
    }
  }
}
