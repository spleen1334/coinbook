{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "read": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "todowrite": "allow",
    "question": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "skill": "allow",
    "task": "allow",
    "edit": "allow",
    "write": "allow",
    "apply_patch": "allow",
    "ast_grep_search": "allow",
    "ast_grep_replace": "allow",
    "gh_grep_searchGitHub": "allow",
    "list_mcp_resources": "allow",
    "list_mcp_resource_templates": "allow",
    "read_mcp_resource": "allow",
    "cancel_task": "allow",
    "bash": {
      "*": "ask",
      "git status": "allow",
      "git status *": "allow",
      "git diff": "allow",
      "git diff *": "allow",
      "git diff --stat": "allow",
      "git log *": "allow",
      "git log --oneline *": "allow",
      "git show *": "allow",
      "git add *": "allow",
      "git commit *": "allow",
      "git add * && git commit *": "allow",
      "npm run check": "allow",
      "npm run format:check": "allow",
      "npm run lint": "allow",
      "npm run build": "allow",
      "npm run build:pages": "allow",
      "npm run deploy": "allow",
      "npx prettier --write *": "allow",
      "npx prettier * --write": "allow",
      "file public/icons/*": "allow",
      "rm *": "deny",
      "sudo *": "deny",
      "git clean *": "deny",
      "git reset --hard *": "deny",
      "git push *": "ask"
    },
    "external_directory": {
      "*": "deny"
    }
  }
}
